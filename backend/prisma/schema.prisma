datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum IssueStatus {
  OPEN
  CLOSED
}

enum ChecklistStatus {
  PENDING
  DONE
}

enum TaskType {
  GITHUB_ISSUE
  GITHUB_PR
  MANUAL
}

model User {
  id             String       @id @default(uuid())
  clerkId        String       @unique
  githubUsername String?      @unique
  email          String?
  name           String?
  avatarUrl      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  repositories   Repository[]
  assignedChecklists Checklist[] @relation("AssignedChecklists")
  createdChecklists  Checklist[] @relation("CreatedChecklists")
}

model Repository {
  id             String                 @id @default(uuid())
  githubRepoId   Int                    @unique
  name           String
  owner          String
  description    String?
  url            String
  isPrivate      Boolean                @default(false)
  imageUrl       String?                // Custom project banner/icon URL
  importedById   String
  importedBy     User                   @relation(fields: [importedById], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  issues         Issue[]
  checklists     Checklist[]
  commitActivity WeeklyCommitActivity[]

  @@index([importedById])
}

model Issue {
  id           String      @id @default(uuid())
  title        String
  description  String?
  status       IssueStatus @default(OPEN)
  type         TaskType    @default(MANUAL)
  githubNumber Int?        // GitHub Issue/PR number (if synced)
  githubUrl    String?     // Link to GitHub page (if synced)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  repositoryId String
  repository   Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  checklists   Checklist[]

  @@unique([repositoryId, githubNumber])
  @@index([repositoryId])
}

model Checklist {
  id           String          @id @default(uuid())
  title        String
  description  String?
  status       ChecklistStatus @default(PENDING)
  type         TaskType        @default(MANUAL)
  githubNumber Int?            // GitHub Issue/PR number (if synced)
  githubUrl    String?         // Link to GitHub page (if synced)
  imageUrl     String?         // Image URL associated with checklist item
  repositoryId String
  repository   Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  issueId      String?
  issue        Issue?          @relation(fields: [issueId], references: [id], onDelete: Cascade)
  assigneeId   String?
  assignee     User?           @relation("AssignedChecklists", fields: [assigneeId], references: [id])
  creatorId    String?
  creator      User?           @relation("CreatedChecklists", fields: [creatorId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([repositoryId])
  @@index([issueId])
  @@index([assigneeId])
}

model WeeklyCommitActivity {
  id           String     @id @default(uuid())
  week         Int        // Unix timestamp for the start of the week
  days         Int[]      // Array of 7 integers representing daily commit counts
  total        Int        // Total commits for the week
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([repositoryId, week])
  @@index([repositoryId])
}
